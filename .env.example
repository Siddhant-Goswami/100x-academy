# Browser-exposed Supabase credentials (anon key is safe to ship).
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# LLM proxy endpoint (Cloudflare Worker). Only used by agent/MCP lessons later.
PUBLIC_LLM_PROXY_URL=https://100x-proxy.YOUR_SUBDOMAIN.workers.dev

# Server-only, used by scripts/sync-lessons.ts at deploy time. Never expose to the browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
